<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/icono_stardewvalley"
        android:label="@string/app_name"
        android:roundIcon="@drawable/icono_stardewvalley"
        android:supportsRtl="true"
        android:theme="@style/Theme.Stardewvalley"
        tools:targetApi="31">

        <!-- MainActivity con la ruta de la carpeta .ui -->
        <activity
            android:name=".ui.screen.LoginScreen"
            android:exported="true"
            android:theme="@style/Theme.App.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Asegúrate de que MainActivity NO tenga el intent-filter de Launcher ahora -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="false" />

    </application>

</manifest>