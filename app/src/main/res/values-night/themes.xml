<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Stardewvalley" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#4E2C12</item>
        <item name="colorPrimaryVariant">#351E0C</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        
        <!-- Fondo de la ventana para evitar el flash blanco en modo oscuro -->
        <item name="android:windowBackground">#2D1C10</item>
        <item name="android:windowDisablePreview">false</item>
    </style>

    <!-- Tema para la Splash Screen en modo oscuro -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#2D1C10</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icono_stardewvalley</item>
        <item name="postSplashScreenTheme">@style/Theme.Stardewvalley</item>
    </style>
</resources>