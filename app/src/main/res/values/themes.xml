<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Stardewvalley" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Colores principales -->
        <item name="colorPrimary">#4E2C12</item>
        <item name="colorPrimaryVariant">#351E0C</item>
        <item name="colorOnPrimary">#FFFFFF</item>

        <!-- Fondo de la ventana para evitar el flash blanco -->
        <item name="android:windowBackground">#F3D091</item> <!-- Color crema/beige Stardew -->
        <item name="android:windowDisablePreview">false</item>
    </style>

    <!-- Tema para la Splash Screen -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#F3D091</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/icono_stardewvalley</item>
        <item name="postSplashScreenTheme">@style/Theme.Stardewvalley</item>
    </style>
</resources>